{% extends "base.html.jinja" %}
{% block title %}Recipes of the day{% endblock %}
{% block content %}

{% for section in sections %}
<section class="front-page-section">
    <h2>{{ section.title }}</h2>
    {% if section.blurb %}<p class="section-blurb">{{ section.blurb }}</p>{% endif %}
    <carousel-strip>
        {% for recipe in section.recipes %}
        <a href="/recipe/{{recipe.recipe_id}}">
            <image-card>
                <h4>{{recipe.name}}</h4>
                {% if recipe.thumbnail_image_id %}
                <img src="/image/{{recipe.thumbnail_image_id}}"
                    alt="{{recipe.name}}" loading="lazy">
                {% endif %}
                {% if recipe.description %}<p class="card-desc">{{recipe.description}}</p>{% endif %}
            </image-card>
        </a>
        {% endfor %}
    </carousel-strip>
</section>
{% endfor %}

{% if highlights %}
<highlight-row>
    {% for highlight in highlights %}
    <highlight-card>
        <h3>{{ highlight.title }}</h3>
        {% set recipe = highlight.recipes[0] %}
        {% if recipe %}
        <a href="/recipe/{{recipe.recipe_id}}">
            <image-card>
                <h4>{{recipe.name}}</h4>
                {% if recipe.thumbnail_image_id %}
                <img src="/image/{{recipe.thumbnail_image_id}}"
                    alt="{{recipe.name}}" loading="lazy">
                {% endif %}
            </image-card>
        </a>
        {% endif %}
    </highlight-card>
    {% endfor %}
</highlight-row>
{% endif %}

{% if articles %}
<h2>From Our Writers</h2>
<article-row>
    {% for item in articles %}
    <article-card {% if item.recipe_image_id %}class="has-image"{% endif %}>
        <a href="/article/{{ item.article.slug }}">
            <article-text>
                <h3>{{ item.article.title }}</h3>
                {% if item.article.summary %}<p>{{ item.article.summary }}</p>{% endif %}
                <span class="article-meta">{{ item.article.publish_date }}</span>
            </article-text>
            {% if item.recipe_image_id %}
            <article-thumb>
                <img src="/image/{{ item.recipe_image_id }}" alt="" loading="lazy">
            </article-thumb>
            {% endif %}
        </a>
    </article-card>
    {% endfor %}
</article-row>
{% endif %}

<h2>Discover More</h2>
<image-cards>
    {% for recipe in recipes %}
    <a href="/recipe/{{recipe.recipe_id}}">
        <image-card>
            <h4>{{recipe.name}}</h4>
            <img src="/image/{{recipe.thumbnail_image_id}}"
                alt="{{recipe.name}}" loading="lazy">
            {% if recipe.description %}<p class="card-desc">{{recipe.description}}</p>{% endif %}
        </image-card>
    </a>
    {% endfor %}
</image-cards>
{% endblock %}
